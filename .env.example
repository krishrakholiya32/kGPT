# ===== Groq =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

LLM_TEMPERATURE=0.7

# ===== JWT Authentication =====
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# Leave as * for local/Docker dev (frontend is served by FastAPI on the same origin).
ALLOWED_ORIGINS=*

# ===== Storage =====
DATABASE_URL=sqlite:///./database/data.db

# ===== Email (Resend) =====
# Sign up at https://resend.com, get a free API key (100 emails/day)
RESEND_API_KEY=your-resend-api-key-here
# Use onboarding@resend.dev for testing, or a verified domain address in production
RESEND_FROM_EMAIL=onboarding@resend.dev
# Full public URL of your app (used in verification links)
APP_BASE_URL=https://k-gpt.duckdns.org
