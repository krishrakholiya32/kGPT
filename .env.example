# ===== LLM mode =====
# online -> cloud LLM (Gemini or Groq)
LLM_MODE=online

# Optional: force a specific provider. One of: gemini | groq  (leave blank to auto-select)
LLM_PROVIDER=

LLM_TEMPERATURE=0.7

# ===== Gemini =====
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ===== Groq =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ===== JWT Authentication =====
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# Set to your frontend URL(s) in production, comma-separated.
# Example: https://your-kgpt.netlify.app
# Leave as * for local/Docker dev (frontend is served by FastAPI on the same origin).
ALLOWED_ORIGINS=*

# ===== Storage =====
DATABASE_URL=sqlite:///./database/data.db
