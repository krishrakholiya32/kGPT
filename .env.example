# ===== LLM mode =====
# online  -> Google Gemini (cloud, needs GEMINI_API_KEY)
# offline -> Ollama / LLaMA3 (local, no key; needs Ollama running)
LLM_MODE=online

# Optional: force a specific provider regardless of LLM_MODE.
# One of: gemini | ollama | groq  (leave blank to use LLM_MODE)
LLM_PROVIDER=

LLM_TEMPERATURE=0.7

# ===== Gemini (online mode) =====
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ===== Ollama (offline mode) =====
# Install from https://ollama.com and run:  ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ===== Groq (optional, set LLM_PROVIDER=groq to use) =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ===== JWT Authentication =====
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# Set to your frontend URL(s) in production, comma-separated.
# Example: https://your-kgpt.netlify.app
# Leave as * for local/Docker dev (frontend is served by FastAPI on the same origin).
ALLOWED_ORIGINS=*

# ===== Storage =====
CHROMA_PERSIST_DIR=./vectorstore
UPLOAD_DIR=./documents
DATABASE_URL=sqlite:///./database/data.db
