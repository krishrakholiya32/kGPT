# ===== Groq =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=openai/gpt-oss-120b
# Optional extra Groq keys (comma-separated) for rotation/fallback.
# GROQ_API_KEYS=key2,key3

# ===== Gemini (fallback) =====
# GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_API_KEYS=key2,key3

LLM_TEMPERATURE=0.7

# ===== JWT Authentication =====
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# Leave as * for local/Docker dev (frontend is served by FastAPI on the same origin).
ALLOWED_ORIGINS=*

# ===== Storage (async Postgres) =====
# Local dev (Postgres on host):
DATABASE_URL=postgresql+asyncpg://kgpt:kgpt@localhost:5432/kgpt
# Under docker-compose the app service overrides this to use host "db".

# ===== Email (Gmail SMTP) =====
# Your Gmail address
SMTP_USER=you@gmail.com
# Gmail App Password (NOT your regular password).
# Enable 2-Step Verification first, then generate one at:
# Google Account → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Display name in the From header
SMTP_FROM_NAME=kGPT
# Full public URL of your app (used in verification links)
APP_BASE_URL=https://kgpt.zrik.tech
