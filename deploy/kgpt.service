[Unit]
Description=kGPT FastAPI app
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/kgpt
EnvironmentFile=/home/ubuntu/kgpt/.env
ExecStart=/home/ubuntu/kgpt/.venv/bin/uvicorn backend.api.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
